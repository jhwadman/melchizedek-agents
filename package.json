{
  "name": "melchizedek-agents",
  "version": "0.1.0",
  "description": "A multi-model, multi-agent orchestration framework on Google ADK — YAML-defined syndicates, Supabase session persistence, pgvector long-term memory. Companion repo to the lyceumagents.com curriculum.",
  "type": "module",
  "license": "MIT",
  "//": "adk + genai are pinned exact: newer genai minors change response part shapes and silently break the chat printer. Bump deliberately, verify a live run, then update the pin.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "chat:syndicate": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts",
    "syndicate:council": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate syndicate",
    "syndicate:delegation": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate delegation",
    "syndicate:critic": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate critic",
    "syndicate:hierarchical": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate hierarchical",
    "syndicate:style": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate style_council",
    "syndicate:image": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate image_production",
    "syndicate:ares": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate ares",
    "syndicate:claude": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate claude",
    "syndicate:advocate": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate patient_advocate",
    "syndicate:hearth": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate hearth",
    "demo:models": "node --disable-warning=DEP0040 --experimental-strip-types scripts/demo_model_optionality.ts",
    "syndicate:agora": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate agora",
    "syndicate:librarian": "node --disable-warning=DEP0040 --experimental-strip-types scripts/syndicate_chat.ts --syndicate librarian",
    "mcp:demo": "node --disable-warning=DEP0040 --experimental-strip-types scripts/demo_mcp_server.ts",
    "start:a2a": "node --disable-warning=DEP0040 --experimental-strip-types scripts/a2a_server.ts",
    "test": "node --disable-warning=DEP0040 --experimental-strip-types --test tests/**/*.test.ts",
    "db:purge": "node --disable-warning=DEP0040 --experimental-strip-types scripts/purge_supabase.ts"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@anthropic-ai/sdk": "^0.96.0",
    "@google/adk": "1.3.0",
    "@google/genai": "2.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@supabase/supabase-js": "^2.43.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "openai": "^6.48.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "typescript": "^5"
  }
}
