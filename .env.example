# ── Required for cloud models ─────────────────────────────────────────────────
# Google AI Studio API key — powers all Gemini model inference.
# Also required for the gemini-embedding-001 embedding model used by long-term memory.
# Get yours free at: https://aistudio.google.com
# NOT needed for all-local syndicates (hearth, agora) — see the Ollama note below.
GOOGLE_GENAI_API_KEY=your_google_ai_studio_api_key_here

# ── Optional: Ollama (open-weight local models) ───────────────────────────────
# NO KEY NEEDED. Syndicates whose every agent uses an ollama/* model id (e.g.
# ollama/qwen3:8b) run entirely on your machine via Ollama's OpenAI-compatible
# API — install from https://ollama.com and `ollama pull qwen3:8b`.
# Set this only to point at a non-default Ollama endpoint.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Optional: MCP (Model Context Protocol) ────────────────────────────────────
# ALLOW_PRIVATE_MCP: set to "true" to permit mcp_server_url values pointing at
# localhost / private / link-local hosts. Off by default as an SSRF guard;
# turn it on for local development — e.g. the librarian demo (npm run mcp:demo).
ALLOW_PRIVATE_MCP=false

# ── Optional: Anthropic / Claude ──────────────────────────────────────────────
# Required only when using claude-* model identifiers in syndicate YAML configs.
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional: Supabase (Session Persistence & Long-Term Memory) ───────────────
# Required when memory_system is "session-only" or "long-term" in a syndicate YAML.
# Without these, the framework falls back to in-memory sessions (no persistence).
#
# Setup: Create a free project at https://supabase.com, then go to:
#   Project Settings → API → Project URL     → paste below as SUPABASE_URL
#   Project Settings → API → service_role key → paste below as SUPABASE_SERVICE_ROLE_KEY
#
# IMPORTANT: Run the SQL schema from DOCUMENTATION.md §4 in your Supabase
# SQL Editor before sessions and memory will work — then run db/hardening.sql.
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Optional: A2A Server ──────────────────────────────────────────────────────
# A2A_SERVER_SECRET: Bearer token used to authenticate incoming A2A requests.
# If set, all requests must include: Authorization: Bearer <this_value>
# If not set, the A2A server runs without authentication (local dev only).
# REQUIRED in production: if PUBLIC_URL is set, the server REFUSES TO START
# without this secret, to avoid exposing an unauthenticated endpoint.
A2A_SERVER_SECRET=your_a2a_server_secret_here

# PUBLIC_URL: The publicly accessible base URL of the A2A server.
# Used when compiling the AgentCard that advertises this agent to A2A clients.
# Defaults to http://localhost:4000 if not set.
# Only needed for cloud deployments where the server has a real public URL.
PUBLIC_URL=
